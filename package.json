{
  "name": "urban-context-analysis",
  "version": "0.1.0",
  "description": "Lightweight urban context analysis MVP for XL/L/M geospatial fact sheets.",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "preprocess:bkg": "node scripts/preprocess/preprocess-bkg-boundaries.mjs",
    "preprocess:fua": "node scripts/preprocess/preprocess-gisco-fua.mjs",
    "preprocess:srtm": "node scripts/preprocess/preprocess-srtm-samples.mjs",
    "preprocess:buildings": "node scripts/preprocess/preprocess-building-fallback.mjs",
    "preprocess:gtfs": "node scripts/preprocess/preprocess-gtfs-stops.mjs",
    "preprocess:thematic": "node scripts/preprocess/preprocess-thematic-geojson.mjs",
    "preprocess:point-cache": "node scripts/preprocess/resolve-point-cache.mjs",
    "validate:ui": "python3 scripts/validate/validate_ui_css.py src/styles/design-system.css src/styles/app.css"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "type": "module",
  "dependencies": {
    "@types/geojson": "^7946.0.16",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "maplibre-gl": "^5.24.0",
    "playwright": "^1.59.1",
    "plotly.js-dist-min": "^3.5.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sql.js": "^1.14.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
